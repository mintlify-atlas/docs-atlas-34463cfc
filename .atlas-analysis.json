  "keyFeatures": [
    "JWT-based authentication system",
    "User registration and login",
    "Unique handle-based user profiles",
    "Profile management with links and descriptions",
    "Image upload integration with Cloudinary",
    "Handle availability search",
    "MongoDB data persistence"
  ],
  "publicApiSurface": [
    "POST /auth/register - Register a new user",
    "POST /auth/login - Authenticate and receive JWT token",
    "GET /user - Get authenticated user profile",
    "GET /:handle - Get user profile by handle",
    "POST /search - Check handle availability",
    "PATCH /user - Update user profile",
    "POST /user/image - Upload user profile image"
  ]
